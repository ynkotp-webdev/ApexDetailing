---
import { Image } from "astro:assets";
import BurgerButton from "../Menu/BurgerButton.astro";
import BurgerPanel from "../Menu/BurgerPanel.astro";
import DesktopNav from "../Menu/Desktop.Nav.astro";
import logo from '../../assets/images/logo.png';
const base = import.meta.env.BASE_URL;
---
<header
    class="sticky top-0 z-30 border-b border-carbon-900/10 bg-clinic-50/80
           backdrop-blur-md supports-backdrop-filter:bg-clinic-50/70"
>
    <div class="container-x flex items-center justify-between gap-4 py-3">
        <a href={base} class="flex shrink-0 items-center gap-3" aria-label="Apex Detailing — на головну">
            <Image
                src={logo}
                alt="Логотип детейлінг сервісу Apex Detailing"
                width={56}
                height={56}
                loading="eager"
                class="h-12 w-12 object-contain"
            />
            <span class="hidden font-display text-base font-semibold text-carbon-900 sm:block">
                Apex&nbsp;Detailing
            </span>
        </a>

        <p class="hidden text-sm text-carbon-700/80 lg:block">
            Більше, ніж просто сервіс!
        </p>

        <div class="flex items-center gap-4">
            <DesktopNav />
            <a href={`${base}contacts#form`} class="btn-primary hidden lg:inline-flex">
                Онлайн запис
            </a>
            <BurgerButton />
        </div>
    </div>
</header>
<BurgerPanel />
