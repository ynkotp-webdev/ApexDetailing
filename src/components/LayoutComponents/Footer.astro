---
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.png';

const base = import.meta.env.BASE_URL;
---
<footer>
	<div class="flex justify-center gap-4">
		<a href={base}>
			<Image
				src={logo}
				alt="Логотип Apex Detailing"
				width={88}
				height={88}
			/>
			 
		</a>
		<div class="flex center ">
			<p>
				Apex Detailing - Більше, ніж просто сервіс!
			</p>
			<p>
				© 2026 Apex Detailing. Всі права захищені.
			</p>
		</div>
		<div>
			<a href="https://www.instagram.com/"> <!--logo instagram --> </a>
			<a href="https://www.facebook.com/"> <!--logo facebook --> </a>
		</div>
	</div>
	<!-- Прибрати на клієнтських сайтах -->
	<div class="border-t border-white/10">
		<p class="mx-auto max-w-7xl px-5 py-5 text-center text-xs opacity-60 sm:px-6">
			Це навчальний проєкт для портфоліо. Усі дані вигадані, будь-які збіги з реальними особами, місцями чи подіями є випадковими та не мають на меті відображення реальності.
		</p>
	</div>
</footer>
