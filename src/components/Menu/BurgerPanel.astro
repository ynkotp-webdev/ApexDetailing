---
// ШАБЛОН: панель, що відкривається + оверлей.
import { Image } from 'astro:assets';
import { links } from '../../data/nav.ts';
import  logo  from '../../assets/images/logo.png';
const base = import.meta.env.BASE_URL;
---
<div
	id="sidebar-overlay"
	class="pointer-events-none fixed inset-0 z-40 bg-black/50 opacity-0 backdrop-blur-sm transition-opacity duration-300 is-open:pointer-events-auto is-open:opacity-100 lg:hidden"
	aria-hidden="true"
>
</div>

<!--
	Панель. id="sidebar" — НЕ міняй.
	┌ базові:   fixed z-50 flex flex-col bg-white text-black transition-transform duration-300
	├ розмір:   h-full w-72 max-w-[85vw]   ← для sidebar
	├ позиція:  left-0 top-0               ← звідки росте
	├ закрито:  -translate-x-full          ← де ховається (за лівим краєм)
	└ відкрито: is-open:translate-x-0       ← куди їде при is-open
	Щоб зробити меню "зверху-вниз" — заміни 3 останні рядки (див. md-файл).
-->
<aside
	id="sidebar"
	class="fixed z-50 flex flex-col bg-white text-black shadow-2xl transition-transform duration-300 ease-out
	       h-full w-72 max-w-[85vw]
    		left-0 top-0  
    		-translate-x-full 
    		is-open:translate-x-0
	       lg:hidden"
	aria-hidden="true"
>
	<div class="flex items-center justify-between border-b border-carbon-900/10 px-6 py-4">
		<span class="flex items-center gap-2 font-display text-lg font-semibold text-carbon-900">
			<Image src={logo} alt="Логотип Apex Detailing" width={40} height={40} class="h-10 w-10 object-contain" />
			Apex Detailing
		</span>

		<button
			type="button"
			id="sidebar-close"
			aria-label="Закрити меню"
			class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-carbon-900 transition hover:bg-carbon-900/10"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="22"
				height="22"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>

	 
	<nav class="flex flex-1 flex-col gap-1 px-4 py-6">
		{
		links.map(link => (
			<a
				href={link.href}
				class="block rounded-lg px-3 py-2.5 text-base font-medium text-carbon-700 transition hover:bg-cobalt-50 hover:text-cobalt-600"
			>
				{link.name}
			</a>
		))}
	</nav>

	<div class="border-t border-carbon-900/10 p-4">
		<a href={`${base}contacts#form`} class="btn-primary w-full">
			Онлайн запис
		</a>
	</div>
</aside>
