---
import { links } from '../../data/nav.ts';
---
<nav class="hidden items-center gap-7 text-sm font-medium text-carbon-700 lg:flex">
	{links.map(link => (
		<a
			href={link.href}
			class="relative py-1 transition-colors hover:text-cobalt-600
			       after:absolute after:inset-x-0 after:-bottom-0.5 after:h-0.5 after:origin-left
			       after:scale-x-0 after:bg-cobalt-500 after:transition-transform
			       hover:after:scale-x-100"
		>{link.name}</a>
	))}
</nav>
